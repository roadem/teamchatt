<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFC0C0C0" />
            <corners
                android:radius="50px"/>
        </shape>
    </item>

    <item
        android:bottom="1px"
        android:left="0.5px"
        android:right="0.5px"
        android:top="0.5px">
        <shape android:shape="rectangle">
            <solid
                android:color="@color/white" />

            <size
                android:height="100px"
                android:width="760px"/>

            <padding
                android:right="20px"
                android:left="20px"
                android:top="20px"
                android:bottom="20px"
                />

            <corners
                android:radius="50px"/>
        </shape>
    </item>

</layer-list>
