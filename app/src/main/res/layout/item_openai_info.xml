<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="5dp"
    android:layout_marginVertical="5dp"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/layout_models_prices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:weightSum="3">
        <!-- Model Name -->
        <TextView
            android:id="@+id/modelName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:layout_weight="0.8"
            android:ellipsize="marquee"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/black"
            />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="10dp"
            android:layout_weight="1.1"
            android:orientation="horizontal"
            android:weightSum="1">

            <!-- Entrée: Nombre de tokens -->
            <TextView
                android:id="@+id/entryTokens"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="0.5"
                android:background="@drawable/button_black_bg"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <!-- Entrée: Consommation en $ -->
            <TextView
                android:id="@+id/entryConsumption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="0.5"
                android:background="@drawable/button_black_bg"
                android:gravity="center"
                android:text="0,00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.1"
            android:orientation="horizontal"
            android:weightSum="1">

            <!-- Sortie: Nombre de tokens -->
            <TextView
                android:id="@+id/outputTokens"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="5dp"
                android:layout_weight="0.5"
                android:background="@drawable/button_black_bg"
                android:gravity="center"
                android:text="0"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />

            <!-- Sortie: Consommation en $ -->
            <TextView
                android:id="@+id/outputConsumption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:background="@drawable/button_black_bg"
                android:gravity="center"
                android:text="0,00"
                android:textColor="#FFFFFF"
                android:textSize="14sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_models_no_prices"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:visibility="gone"
        android:weightSum="3"
        android:layout_marginEnd="10dp">

        <!-- Sortie: Nombre de tokens -->
        <TextView
            android:id="@+id/model_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:gravity="center"
            android:textColor="@color/black"
            android:textSize="14sp"

            android:layout_marginEnd="10dp"/>

        <TextView
            android:id="@+id/token_number_entry"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/button_black_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_weight="0.9"
            android:layout_marginEnd="10dp" />

        <TextView
            android:id="@+id/token_number_output"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:background="@drawable/button_black_bg"
            android:gravity="center"
            android:text="0"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:layout_weight="0.9"/>
    </LinearLayout>

</LinearLayout>

