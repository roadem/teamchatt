<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/receive_message_shape">

        <TextView
            android:id="@+id/txt_receive_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Message receive"
            android:padding="10dp"
            android:textSize="20px"/>
        <TextView
            android:id="@+id/txt_response_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/txt_receive_message"
            android:layout_alignEnd="@+id/txt_receive_message"
            android:padding="5dp"

            android:text="Response Time"
            android:textColor="@android:color/black"
            android:textSize="18px" />

    </RelativeLayout>

</RelativeLayout>