<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/parent_chat"
    tools:context=".activities.ChatWindow">

    <RelativeLayout
        android:id="@+id/relative_layout_parent_chat"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_black">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_blue">

            <RelativeLayout
                android:id="@+id/lyt_close_menu_chat"
                android:layout_width="100px"
                android:layout_height="100px"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="20px"
                android:layout_marginEnd="140px"
                android:clickable="true"
                android:elevation="0.8dp"
                android:background="@drawable/ellipse_opened"
                android:onClick="btnCloseChat">
                <ImageView
                    android:id="@+id/button_close_menu_chat"
                    android:layout_width="36px"
                    android:layout_height="37px"
                    android:layout_centerInParent="true"
                    android:src="@drawable/chat"
                    android:tint="@color/white" />
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/layout_chat"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="60px"
                android:layout_marginBottom="20px"
                android:layout_marginTop="140px"
                android:background="@drawable/window_bg">

                <ScrollView
                    android:id="@+id/scrollview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginBottom="120px"
                    android:paddingHorizontal="20dp"
                    android:paddingTop="20dp"
                    android:orientation="vertical">
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/chatRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentTop="true"/>
                </ScrollView>

                <ImageView
                    android:id="@+id/micro_btn"
                    android:layout_width="90px"
                    android:layout_height="90px"
                    android:layout_alignParentBottom="true"
                    android:layout_centerHorizontal="true"
                    android:layout_marginBottom="20px"
                    android:clickable="true"
                    android:elevation="0.8dp"
                    android:onClick="onClickMicro"
                    android:src="@drawable/micro_off" />
                <ImageView
                    android:id="@+id/send_btn"
                    android:layout_width="75px"
                    android:layout_height="75px"
                    android:src="@drawable/send_btn"
                    android:clickable="true"
                    android:elevation="0.8dp"
                    android:layout_marginBottom="20px"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentEnd="true"
                    android:layout_marginRight="15px"
                    android:onClick="onClickSend"/>

                <ImageView
                    android:id="@+id/clear_btn"
                    android:layout_width="75px"
                    android:layout_height="75px"
                    android:src="@drawable/clear_conversation_btn"
                    android:clickable="true"
                    android:elevation="0.8dp"
                    android:layout_marginBottom="20px"
                    android:layout_alignParentBottom="true"
                    android:layout_alignParentStart="true"
                    android:layout_marginLeft="15px"
                    android:onClick="onClickClearConversation"/>

            </RelativeLayout>

        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/popup_add_mail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#99000000"
            android:visibility="invisible">
            <LinearLayout
                android:id="@+id/popup_add_mail_linearLayout"
                android:layout_width="300dp"
                android:layout_height="130dp"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:background="@drawable/window_bg"
                android:elevation="0.8dp"
                android:padding="16dp"
                >

                <TextView
                    android:id="@+id/popup_add_mail_textView"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textAlignment="center"
                    android:layout_marginBottom="5dp"
                    android:text="@string/destination_mail_texte_fr"
                    android:textColor="#000000" />

                <EditText
                    android:id="@+id/editTextEmail"
                    android:layout_marginTop="5dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal|center_vertical"
                    android:hint="@string/destination_mail_Edittexte_fr"
                    android:importantForAutofill="noExcludeDescendants"
                    android:inputType="textEmailAddress"
                    android:textAlignment="center"
                    android:textColor="#FFFFFF"
                    android:textColorHint="#989494"
                    android:textSize="15sp"
                    android:background="@drawable/button_black_bg"/>

                <ImageView
                    android:id="@+id/send_btn2"
                    android:layout_width="50px"
                    android:layout_height="50px"
                    android:src="@drawable/send_btn"
                    android:clickable="true"
                    android:elevation="0.8dp"
                    android:layout_marginTop="15dp"
                    android:layout_gravity="end"
                    android:onClick="onClickSendFromPopup"
                    />
            </LinearLayout>

        </RelativeLayout>


    </RelativeLayout>

</RelativeLayout>